# Application Settings
APP_NAME=GramSaarthi
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS Settings
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

# Leave empty for AWS; set only for local/testing endpoints
DYNAMODB_ENDPOINT_URL=

# DynamoDB Tables
DYNAMODB_USERS_TABLE=gramsaarthi-users-dev
DYNAMODB_FORECASTS_TABLE=gramsaarthi-forecasts-dev
DYNAMODB_SCHEMES_TABLE=gramsaarthi-schemes-dev
DYNAMODB_REPORTS_TABLE=gramsaarthi-reports-dev
DYNAMODB_CHAT_SESSIONS_TABLE=gramsaarthi-chat-sessions-dev

# S3 Buckets
S3_DATA_BUCKET=gramsaarthi-data-dev
S3_REPORTS_BUCKET=gramsaarthi-reports-dev
S3_SCHEMES_BUCKET=gramsaarthi-schemes-dev
S3_SCHEMES_PREFIX=schemes

# Bedrock Settings
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_INFERENCE_PROFILE_ID=apac.amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_MAX_TOKENS=512
BEDROCK_TEMPERATURE=0.2

# ChromaDB Settings
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=schemes

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Settings
HOST=0.0.0.0
PORT=8000
